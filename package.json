{
  "name": "avernethwebv2",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "fuser -k 5000/tcp 2>/dev/null || true && next dev -p 5000",
    "build": "next build",
    "start": "fuser -k 5000/tcp 2>/dev/null || true && next start -p 5000",
    "lint": "next lint",
    "build:prod": "set NODE_ENV=production&& next build",
    "build:prod:linux": "NODE_ENV=production next build",
    "start:prod": "fuser -k 5000/tcp 2>/dev/null || true && set NODE_ENV=production&& next start -p 5000",
    "deploy": "npm run build:prod && npm run start:prod"
  },
  "dependencies": {
    "autoprefixer": "^10.4.27",
    "bcrypt": "^5.1.1",
    "cookie": "^0.6.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.9.7",
    "next": "14.2.5",
    "postcss": "^8.5.8",
    "react": "^18",
    "react-dom": "^18",
    "tailwindcss": "^3.4.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "18.3.28",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "typescript": "5.9.3"
  }
}
